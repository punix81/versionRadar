{
  "name": "version-radar",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "fetch-pipelines": "ts-node --project tsconfig.scripts.json scripts/fetch-pipeline-versions.ts",
    "fetch-pipelines:python": "python3 scripts/fetch_pipeline_versions.py",
    "fetch-packages": "ts-node --project tsconfig.scripts.json scripts/fetch-package-versions.ts",
    "fetch-packages:python": "python3 scripts/fetch_package_versions.py"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@10.8.2",
  "dependencies": {
    "@angular/cdk": "^21.1.4",
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/material": "^21.1.4",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "echarts": "^6.0.0",
    "js-yaml": "^4.1.1",
    "ngx-echarts": "^21.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.4",
    "@angular/cli": "^21.1.4",
    "@angular/compiler-cli": "^21.1.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.2.3",
    "dotenv": "^17.3.1",
    "jsdom": "^27.1.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
